<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="DailyConditionApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:DailyConditionApp"
    xmlns:views="clr-namespace:DailyConditionApp.Views"
    Title="DailyConditionApp">
    <Shell.FlyoutHeader>
        <Grid BackgroundColor="{StaticResource Primary}" HeightRequest="150">
            <Label
                HorizontalOptions="Center"
                Text="マイメニュー"
                TextColor="White"
                VerticalOptions="Center" />
        </Grid>
    </Shell.FlyoutHeader>

    <FlyoutItem Title="トップページ">
        <ShellContent ContentTemplate="{DataTemplate views:MainView}" Route="MainView" />
    </FlyoutItem>

    <FlyoutItem Title="今日のコンディション入力">
        <ShellContent ContentTemplate="{DataTemplate views:DailyInputView}" Route="DailyInputView" />
    </FlyoutItem>

    <FlyoutItem Title="結果表示">
        <ShellContent ContentTemplate="{DataTemplate views:DailyConditionResultView}" Route="DailyConditionResultView" />
    </FlyoutItem>

</Shell>
