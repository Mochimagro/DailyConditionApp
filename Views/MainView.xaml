<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="DailyConditionApp.Views.MainView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:DailyConditionApp.Views"
    xmlns:vm="clr-namespace:DailyConditionApp.ViewModels"
    Title="トップ">
    <VerticalStackLayout Padding="30" Spacing="20">
        <Label
            FontSize="24"
            HorizontalOptions="Center"
            Text="{Binding Title}" />
        <Button Command="{Binding GoToDailyInputCommand}" Text="今日のコンディションを入力する" />
    </VerticalStackLayout>
</ContentPage>