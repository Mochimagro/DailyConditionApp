<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="DailyConditionApp.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <VerticalStackLayout Padding="12" Spacing="8">
        <Label
            FontAttributes="Bold"
            HorizontalOptions="Start"
            Text="設定" />
        <Label Text="APIキー" />
        <Entry
            Placeholder="APIキーを入力"
            Text="{Binding ApiKey, Mode=TwoWay}" />
        <Label
            FontSize="12"
            Text="※このAPIキーはデバイスに保存されます。"
            TextColor="Gray" />
    </VerticalStackLayout>
</ContentPage>
