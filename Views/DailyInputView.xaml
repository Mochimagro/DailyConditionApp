<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="DailyConditionApp.Views.DailyInputView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Label Text="睡眠時間（HH:mm）" />
            <Entry
                Keyboard="Time"
                Placeholder="例: 07:30"
                Text="{Binding SleepTime, Mode=TwoWay}" />


            <Label Text="睡眠効率（％）" />
            <Entry
                Keyboard="Numeric"
                Placeholder="例: 85"
                Text="{Binding SleepEfficiency, Mode=TwoWay}" />

            <Button
                Margin="0,10"
                BackgroundColor="LightBlue"
                Command="{Binding FetchWeatherCommand}"
                Text="現在の天気を自動取得"
                TextColor="Black" />

            <Label Text="天気" />
            <Picker
                Title="選択してください"
                ItemsSource="{Binding WeatherOptions}"
                SelectedItem="{Binding Weather, Mode=TwoWay}" />

            <Label Text="気圧（hPa）" />
            <Entry
                Keyboard="Numeric"
                Placeholder="例: 1013.25"
                Text="{Binding Pressure, Mode=TwoWay}" />

            <Label Text="風速（m/s）" />
            <Entry
                Keyboard="Numeric"
                Placeholder="例: 3.2"
                Text="{Binding WindSpeed, Mode=TwoWay}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>