<ContentView
    x:Class="DailyConditionApp.Views.Controls.LoadingView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="this"
    IsVisible="{Binding IsBusy}">
    <Grid>
        <BoxView BackgroundColor="Black" Opacity="0.3" />

        <VerticalStackLayout
            HorizontalOptions="Center"
            Spacing="10"
            VerticalOptions="Center">
            <ActivityIndicator
                HeightRequest="50"
                IsRunning="True"
                WidthRequest="50"
                Color="DodgerBlue" />
            <Label
                HorizontalOptions="Center"
                Text="読み込み中..."
                TextColor="White" />
        </VerticalStackLayout>
    </Grid>
</ContentView>